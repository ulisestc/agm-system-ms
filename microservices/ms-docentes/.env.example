# ── Base de datos independiente del MS-3 ──────────────────────────────────────
DB_URL=postgresql://postgres:root@localhost:5432/agm_docentes_db

# ── Puerto REST (FastAPI / Uvicorn) ───────────────────────────────────────────
REST_PORT=8003

# ── Puerto gRPC (servidor interno) ────────────────────────────────────────────
GRPC_PORT=50053

# ── Seguridad interna entre microservicios ────────────────────────────────────
INTERNAL_SECRET=your_super_secret_key_here
